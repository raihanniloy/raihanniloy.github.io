---
import BaseLayout from '../layouts/BaseLayout.astro';
import ExperienceItem from '../components/ExperienceItem.astro';
import { experience } from '../data/experience';

const workItems      = experience.filter(e => e.type === 'work');
const educationItems = experience.filter(e => e.type === 'education');
---

<BaseLayout title="Experience — Raihan Kader Niloy">
  <div class="container page">
    <section>
      <h2>Work Experience</h2>
      <p class="section-subtitle">My professional journey</p>
      <div class="timeline">
        {workItems.map(item => <ExperienceItem item={item} />)}
      </div>
    </section>

    <section>
      <h2>Education</h2>
      <p class="section-subtitle">Academic background</p>
      <div class="timeline">
        {educationItems.map(item => <ExperienceItem item={item} />)}
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .page {
    padding-top: 3rem;
    padding-bottom: 4rem;
  }

  .timeline {
    max-width: 700px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
</style>
