// Drop this file into your src/pages/ folder replacing the existing index.astro
---

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Raihan Niloy — Full-Stack Engineer</title>
<meta name="description" content="Full-Stack Software Engineer with 7+ years building enterprise systems, ETL pipelines, government platforms, and ML tools." />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Space+Mono:ital,wght@0,400;0,700;1,400;1,700&display=swap" rel="stylesheet" />

<style>
:root {
  --bg:       #1e2633;
  --bg-dark:  #161c27;
  --fg:       #FFFFFF;
  --fg2:      #ABB2BF;
  --fg3:      #C1C8D4;
  --accent:   #49cab5;
  --border:   #4B5362;
  --red:      #E06B74;
  --green:    #98C379;
  --yellow:   #E5C07A;
  --blue:     #62AEEF;
  --cyan:     #55B6C2;
  --font: 'Space Mono', monospace;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
body {
  background: var(--bg);
  color: var(--fg);
  font-family: var(--font);
  overflow-x: hidden;
  cursor: none;
}
a { color: inherit; text-decoration: none; }
img { max-width: 100%; }

/* ── CUSTOM CURSOR ──────────────────────────────────────── */
#cursor {
  position: fixed; top: 0; left: 0; z-index: 9999;
  width: 12px; height: 12px;
  background: var(--accent);
  pointer-events: none;
  mix-blend-mode: difference;
  border-radius: 50%;
  transition: transform 0.15s ease, width 0.2s, height 0.2s;
}
#cursor.hover { width: 40px; height: 40px; transform: translate(-14px, -14px); }
#cursor-trail {
  position: fixed; top: 0; left: 0; z-index: 9998;
  width: 32px; height: 32px;
  border: 1px solid var(--accent);
  border-radius: 50%;
  pointer-events: none;
  opacity: 0.4;
  transition: top 0.08s, left 0.08s;
}

/* ── NAV ────────────────────────────────────────────────── */
nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 900;
  display: flex; align-items: center; justify-content: space-between;
  padding: 20px 48px;
  border-bottom: 1px solid transparent;
  transition: border-color 0.4s, background 0.4s, backdrop-filter 0.4s;
}
nav.scrolled {
  border-color: var(--border);
  background: rgba(22,28,39,0.9);
  backdrop-filter: blur(12px);
}
.nav-logo {
  display: flex; align-items: center; gap: 10px;
  font-size: 14px; font-weight: 700; color: var(--fg);
}
.nav-logo-mark { position: relative; width: 24px; height: 24px; }
.nav-links { display: flex; gap: 32px; }
.nav-links a {
  font-size: 13px; color: var(--fg2);
  position: relative; transition: color 0.2s;
}
.nav-links a::before { content: '#'; color: var(--accent); margin-right: 2px; }
.nav-links a::after {
  content: ''; position: absolute; bottom: -3px; left: 0; right: 0;
  height: 1px; background: var(--accent);
  transform: scaleX(0); transform-origin: left;
  transition: transform 0.25s ease;
}
.nav-links a:hover { color: var(--fg); }
.nav-links a:hover::after { transform: scaleX(1); }

/* ── SIDEBAR ────────────────────────────────────────────── */
.sidebar {
  position: fixed; left: 17px; top: 50%; transform: translateY(-50%);
  z-index: 800;
  display: flex; flex-direction: column; align-items: center; gap: 16px;
}
.sidebar::before, .sidebar::after {
  content: ''; display: block; width: 1px; height: 60px; background: var(--border);
}
.sidebar a { opacity: 0.5; transition: opacity 0.2s; }
.sidebar a:hover { opacity: 1; }
.sidebar svg { display: block; }

/* ── DOTS ───────────────────────────────────────────────── */
.dots { display: grid; gap: 6px; opacity: 0.35; }
.dots span { display: block; width: 4px; height: 4px; border-radius: 50%; background: var(--fg2); }

/* ── SECTION HEADING ────────────────────────────────────── */
.section-head { display: flex; align-items: center; gap: 16px; margin-bottom: 64px; }
.section-head h2 { font-size: 32px; font-weight: 700; white-space: nowrap; }
.section-head h2 span { color: var(--accent); }
.section-head-line {
  flex: 1; height: 1px; background: var(--accent);
  transform-origin: left; animation: line-in 0.8s ease forwards;
}
@keyframes line-in { from { transform: scaleX(0); } to { transform: scaleX(1); } }

/* ── REVEAL ─────────────────────────────────────────────── */
.reveal {
  opacity: 0; transform: translateY(32px);
  transition: opacity 0.7s cubic-bezier(0.22,1,0.36,1), transform 0.7s cubic-bezier(0.22,1,0.36,1);
}
.reveal.visible { opacity: 1; transform: none; }

/* ── HERO ───────────────────────────────────────────────── */
#hero {
  min-height: 100vh;
  display: flex; align-items: center;
  padding: 120px 48px 80px 96px;
  position: relative; overflow: hidden;
}
.hero-bg-text {
  position: absolute; right: -20px; top: 50%; transform: translateY(-50%);
  font-size: clamp(180px, 20vw, 320px);
  font-weight: 700; color: transparent;
  -webkit-text-stroke: 1px var(--border);
  line-height: 1; pointer-events: none; user-select: none;
  letter-spacing: -0.05em; opacity: 0.4;
}
.hero-content { max-width: 700px; position: relative; z-index: 1; }
.hero-greeting {
  font-size: 14px; color: var(--accent); margin-bottom: 20px;
  display: flex; align-items: center; gap: 12px;
}
.hero-greeting::before { content: '//'; opacity: 0.6; }
.hero-name {
  font-size: clamp(48px, 7vw, 96px);
  font-weight: 700; line-height: 1.0;
  margin-bottom: 12px; letter-spacing: -0.03em;
}
.hero-name .accent { color: var(--accent); }
.hero-role { font-size: 18px; color: var(--fg2); margin-bottom: 32px; line-height: 1.5; }
.hero-role strong { color: var(--cyan); }
.hero-desc { font-size: 16px; color: var(--fg2); line-height: 1.8; max-width: 480px; margin-bottom: 48px; }
.hero-cta { display: flex; gap: 16px; flex-wrap: wrap; }
.btn {
  font-family: var(--font); font-size: 14px;
  padding: 10px 24px; border: 1px solid var(--accent);
  color: var(--fg); background: transparent;
  cursor: pointer; transition: all 0.2s;
  position: relative; overflow: hidden;
}
.btn::before {
  content: ''; position: absolute; inset: 0;
  background: var(--accent); transform: translateX(-100%);
  transition: transform 0.25s ease; z-index: 0;
}
.btn:hover::before { transform: translateX(0); }
.btn span { position: relative; z-index: 1; }
.btn:hover { color: var(--bg); }
.btn-ghost { border-color: var(--border); }
.btn-ghost::before { background: var(--border); }
.hero-scroll {
  position: absolute; bottom: 40px; left: 50%; transform: translateX(-50%);
  font-size: 11px; color: var(--fg2); letter-spacing: 0.2em;
  display: flex; flex-direction: column; align-items: center; gap: 8px;
  animation: bob 2s ease-in-out infinite;
}
.hero-scroll-line { width: 1px; height: 60px; background: linear-gradient(to bottom, var(--accent), transparent); }
@keyframes bob {
  0%,100% { transform: translateX(-50%) translateY(0); }
  50% { transform: translateX(-50%) translateY(8px); }
}

/* ── GLITCH ─────────────────────────────────────────────── */
.glitch { position: relative; }
.glitch:hover::before, .glitch:hover::after {
  content: attr(data-text);
  position: absolute; top: 0; left: 0; width: 100%; height: 100%;
  background: var(--bg);
}
.glitch:hover::before {
  left: 2px; color: var(--cyan);
  clip: rect(0, 900px, 8px, 0);
  animation: glitch-a 0.2s steps(2) infinite;
}
.glitch:hover::after {
  left: -2px; color: var(--red);
  clip: rect(0, 900px, 16px, 0);
  animation: glitch-b 0.3s steps(2) infinite;
}
@keyframes glitch-a {
  0%   { clip: rect(12px,900px,24px,0); } 25% { clip: rect(60px,900px,72px,0); }
  50%  { clip: rect(4px,900px,16px,0); }  75% { clip: rect(44px,900px,56px,0); }
  100% { clip: rect(28px,900px,40px,0); }
}
@keyframes glitch-b {
  0%   { clip: rect(36px,900px,48px,0); } 25% { clip: rect(8px,900px,20px,0); }
  50%  { clip: rect(52px,900px,64px,0); } 75% { clip: rect(20px,900px,32px,0); }
  100% { clip: rect(68px,900px,80px,0); }
}

/* ── LAYOUT ─────────────────────────────────────────────── */
.section-wrap { max-width: 1200px; margin: 0 auto; padding: 100px 48px; }

/* ── ABOUT ──────────────────────────────────────────────── */
#about { position: relative; }
#about .bg-text {
  position: absolute; right: 40px; top: 80px;
  font-size: 160px; font-weight: 700; color: transparent;
  -webkit-text-stroke: 1px var(--border);
  opacity: 0.2; pointer-events: none; user-select: none; line-height: 1;
}
.about-grid { display: grid; grid-template-columns: 1fr 340px; gap: 80px; align-items: start; }
.about-text p { font-size: 16px; line-height: 1.9; color: var(--fg2); margin-bottom: 20px; }
.about-text p strong { color: var(--fg); }
.about-facts { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 32px; }
.fact-tag {
  border: 1px solid var(--border); padding: 6px 14px;
  font-size: 12px; color: var(--fg2); transition: border-color 0.2s, color 0.2s;
}
.fact-tag:hover { border-color: var(--accent); color: var(--fg); }
.about-photo-wrap { position: relative; }
.about-photo {
  width: 100%; aspect-ratio: 2/3;
  background: var(--bg-dark); border: 1px solid var(--border);
  display: flex; align-items: center; justify-content: center;
  position: relative; overflow: hidden;
}
/* Replace the ::before with a real <img> tag when you have a photo */
.about-photo::before {
  content: '// PHOTO\A// PLACEHOLDER';
  white-space: pre; text-align: center; color: var(--border); font-size: 11px;
}
.about-photo-corner { position: absolute; width: 24px; height: 24px; border-color: var(--accent); border-style: solid; }
.about-photo-corner.tl { top: -1px; left: -1px; border-width: 2px 0 0 2px; }
.about-photo-corner.tr { top: -1px; right: -1px; border-width: 2px 2px 0 0; }
.about-photo-corner.bl { bottom: -1px; left: -1px; border-width: 0 0 2px 2px; }
.about-photo-corner.br { bottom: -1px; right: -1px; border-width: 0 2px 2px 0; }

/* ── EXPERIENCE ─────────────────────────────────────────── */
#experience { background: var(--bg-dark); }
.exp-list { display: flex; flex-direction: column; }
.exp-item {
  display: grid; grid-template-columns: 200px 1fr;
  gap: 40px; padding: 40px 0; border-bottom: 1px solid var(--border);
  position: relative;
}
.exp-item::before {
  content: ''; position: absolute; left: -48px; top: 0;
  width: 3px; height: 0; background: var(--accent); transition: height 0.5s ease;
}
.exp-item.visible::before { height: 100%; }
.exp-meta { padding-top: 4px; }
.exp-period { font-size: 12px; color: var(--accent); margin-bottom: 6px; }
.exp-type { font-size: 11px; color: var(--fg2); border: 1px solid var(--border); display: inline-block; padding: 2px 8px; margin-top: 8px; }
.exp-role { font-size: 22px; font-weight: 700; margin-bottom: 4px; }
.exp-org { font-size: 16px; color: var(--accent); margin-bottom: 16px; }
.exp-desc { font-size: 15px; color: var(--fg2); line-height: 2.4; }
.exp-desc-line { padding: 4px 0; }

/* ── PROJECTS ───────────────────────────────────────────── */
.projects-grid {
  display: grid; grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
  gap: 1px; background: var(--border); border: 1px solid var(--border);
}
.project-card {
  background: var(--bg); padding: 32px;
  position: relative; transition: background 0.25s;
  display: flex; flex-direction: column;
}
.project-card:hover { background: rgba(73,202,181,0.04); }
.project-card-header { display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: 16px; }
.project-num { font-size: 48px; font-weight: 700; line-height: 1; color: var(--border); user-select: none; }
.project-type-badge { font-size: 10px; color: var(--fg2); border: 1px solid var(--border); padding: 3px 8px; letter-spacing: 0.1em; text-transform: uppercase; }
.project-title { font-size: 20px; font-weight: 700; margin-bottom: 10px; color: var(--fg); }
.project-desc { font-size: 15px; color: var(--fg2); line-height: 1.7; margin-bottom: 24px; flex: 1; }
.project-tags { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 20px; }
.project-tag { font-size: 11px; border: 1px solid var(--border); padding: 3px 10px; color: var(--fg2); transition: border-color 0.2s, color 0.2s; }
.project-tag:hover { border-color: var(--accent); color: var(--accent); }
.project-link { font-size: 12px; color: var(--accent); display: inline-flex; align-items: center; gap: 6px; transition: gap 0.2s; }
.project-link:hover { gap: 10px; }
.project-accent-bar {
  position: absolute; bottom: 0; left: 0; right: 0; height: 2px; background: var(--accent);
  transform: scaleX(0); transform-origin: left; transition: transform 0.3s ease;
}
.project-card:hover .project-accent-bar { transform: scaleX(1); }

/* ── SKILLS ─────────────────────────────────────────────── */
#skills { background: var(--bg-dark); }
.skills-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px; background: var(--border); border: 1px solid var(--border); }
.skill-block { background: var(--bg-dark); }
.skill-block-head { padding: 14px 20px; border-bottom: 1px solid var(--border); font-size: 13px; font-weight: 700; display: flex; align-items: center; gap: 8px; }
.skill-block-head .dot { width: 8px; height: 8px; border-radius: 50%; background: var(--accent); }
.skill-block-body { padding: 16px 20px; }
.skill-item { display: flex; align-items: center; gap: 10px; font-size: 14px; color: var(--fg2); padding: 7px 0; border-bottom: 1px solid rgba(75,83,98,0.3); }
.skill-item:last-child { border-bottom: none; }
.skill-item::before { content: '>'; color: var(--accent); font-size: 11px; }

/* ── CONTACT ────────────────────────────────────────────── */
#contact { position: relative; overflow: hidden; }
.contact-bg { position: absolute; inset: 0; z-index: 0; background: radial-gradient(ellipse at 60% 50%, rgba(73,202,181,0.08) 0%, transparent 60%); }
.contact-inner { position: relative; z-index: 1; }
.contact-big { font-size: clamp(48px, 8vw, 96px); font-weight: 700; line-height: 1; margin-bottom: 32px; letter-spacing: -0.03em; }
.contact-big span { color: var(--accent); }
.contact-sub { font-size: 16px; color: var(--fg2); max-width: 420px; line-height: 1.8; margin-bottom: 48px; }
.contact-methods { display: flex; gap: 16px; flex-wrap: wrap; }
.contact-link { display: inline-flex; align-items: center; gap: 10px; font-size: 13px; color: var(--fg2); border: 1px solid var(--border); padding: 12px 20px; transition: all 0.2s; }
.contact-link:hover { border-color: var(--accent); color: var(--fg); }
.contact-link span { color: var(--accent); }

/* ── FOOTER ─────────────────────────────────────────────── */
footer { border-top: 1px solid var(--border); padding: 24px 48px; display: flex; align-items: center; justify-content: space-between; font-size: 12px; color: var(--fg2); }
.footer-logo { display: flex; align-items: center; gap: 8px; }
</style>
</head>
