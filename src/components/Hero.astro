---
---

<section class="hero">
  <div class="container hero-inner">
    <div class="hero-text">
      <p class="hero-greeting">👋 Hello, I'm</p>
      <h1>Raihan Kader<br/>Niloy</h1>
      <p class="hero-subtitle">
        A full-stack software engineer with 7+ years of experience building enterprise systems,
        data platforms, and ML-powered tools across Java, Python &amp; JavaScript stacks.
      </p>
      <div class="hero-ctas">
        <a href="/projects" class="btn btn-primary">View Projects</a>
        <a href="#contact" class="btn btn-outline">Contact Me</a>
      </div>
    </div>
    <div class="hero-image">
      <div class="image-frame">
        <img src="/images/profile.png" alt="Raihan Kader Niloy" width="380" height="380" />
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    background: var(--bg-hero);
    padding: 4rem 0 5rem;
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    align-items: center;
    gap: 3rem;
  }

  .hero-greeting {
    font-size: 1.1rem;
    color: var(--fg-secondary);
    margin-bottom: 0.75rem;
  }

  h1 {
    font-size: clamp(2.5rem, 5.5vw, 3.75rem);
    font-weight: 800;
    margin-bottom: 1.25rem;
  }

  .hero-subtitle {
    font-size: 1.05rem;
    color: var(--fg-secondary);
    line-height: 1.7;
    margin-bottom: 2rem;
    max-width: 480px;
  }

  .hero-ctas {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .hero-image {
    display: flex;
    justify-content: center;
  }

  .image-frame {
    width: 340px;
    height: 340px;
    border-radius: 24px;
    overflow: hidden;
    background: var(--bg);
    box-shadow: var(--shadow-hover);
    border: 3px solid var(--border);
  }

  .image-frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (max-width: 768px) {
    .hero-inner {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .hero-subtitle {
      margin-left: auto;
      margin-right: auto;
    }

    .hero-ctas {
      justify-content: center;
    }

    .image-frame {
      width: 260px;
      height: 260px;
    }
  }
</style>
