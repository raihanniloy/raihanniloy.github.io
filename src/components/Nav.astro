---
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/projects', label: 'Projects' },
  { href: '/experience', label: 'Experience' },
  { href: '/#contact', label: 'Contact' },
];
const currentPath = Astro.url.pathname;
---

<nav class="nav">
  <div class="container nav-inner">
    <a href="/" class="nav-brand">
      <span class="brand-dot"></span>
      RKN
    </a>
    <input type="checkbox" id="nav-toggle" class="nav-toggle" aria-label="Toggle navigation" />
    <label for="nav-toggle" class="nav-hamburger" aria-hidden="true">
      <span></span><span></span><span></span>
    </label>
    <ul class="nav-links">
      {navLinks.map(link => (
        <li>
          <a
            href={link.href}
            class:list={['nav-link', { active: currentPath === link.href || (link.href !== '/' && !link.href.startsWith('/#') && currentPath.startsWith(link.href)) }]}
          >
            {link.label}
          </a>
        </li>
      ))}
      <li>
        <a href="/#contact" class="btn btn-primary nav-cta">Get in Touch</a>
      </li>
    </ul>
  </div>
</nav>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(255, 251, 240, 0.92);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 4rem;
  }

  .nav-brand {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--fg);
    text-decoration: none;
    font-family: 'Playfair Display', serif;
  }

  .brand-dot {
    display: inline-block;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--accent);
  }

  .nav-toggle {
    display: none;
  }

  .nav-hamburger {
    display: none;
    flex-direction: column;
    justify-content: space-between;
    width: 1.5rem;
    height: 1.1rem;
    cursor: pointer;
  }

  .nav-hamburger span {
    display: block;
    height: 2px;
    background: var(--fg);
    border-radius: 2px;
    transition: all 0.2s;
  }

  .nav-links {
    display: flex;
    list-style: none;
    gap: 1.75rem;
    align-items: center;
  }

  .nav-link {
    color: var(--fg-secondary);
    font-size: 0.92rem;
    font-weight: 500;
    text-decoration: none;
    transition: color 0.2s;
  }

  .nav-link:hover,
  .nav-link.active {
    color: var(--fg);
    text-decoration: none;
  }

  .nav-cta {
    padding: 0.5rem 1.25rem;
    font-size: 0.85rem;
    text-decoration: none;
  }

  .nav-cta:hover {
    text-decoration: none;
  }

  @media (max-width: 640px) {
    .nav-hamburger {
      display: flex;
    }

    .nav-links {
      display: none;
      flex-direction: column;
      gap: 0;
      position: absolute;
      top: 4rem;
      left: 0;
      right: 0;
      background: var(--bg);
      border-bottom: 1px solid var(--border);
      padding: 1rem 0;
      box-shadow: var(--shadow);
    }

    .nav-links li {
      width: 100%;
    }

    .nav-link {
      display: block;
      padding: 0.75rem 1.5rem;
    }

    .nav-cta {
      margin: 0.5rem 1.5rem;
      text-align: center;
      display: block;
    }

    .nav-toggle:checked ~ .nav-links {
      display: flex;
    }

    .nav-toggle:checked ~ .nav-hamburger span:nth-child(1) {
      transform: translateY(7px) rotate(45deg);
    }

    .nav-toggle:checked ~ .nav-hamburger span:nth-child(2) {
      opacity: 0;
    }

    .nav-toggle:checked ~ .nav-hamburger span:nth-child(3) {
      transform: translateY(-7px) rotate(-45deg);
    }
  }
</style>
