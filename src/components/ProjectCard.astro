---
import type { Project } from '../data/projects';

interface Props {
  project: Project;
}

const { project } = Astro.props;
---

<article class="card">
  <div class="card-top">
    <span class:list={['badge', project.type]}>{project.type}</span>
    {project.url && (
      <a href={project.url} target="_blank" rel="noopener noreferrer" class="card-arrow" aria-label="View project">→</a>
    )}
  </div>
  <h3>{project.title}</h3>
  <p class="card-desc">{project.description}</p>
  <div class="card-tags">
    {project.tags.map(tag => <span class="tag">{tag}</span>)}
  </div>
</article>

<style>
  .card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .card:hover {
    border-color: var(--accent);
    box-shadow: var(--shadow-hover);
  }

  .card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .badge {
    font-size: 0.7rem;
    padding: 0.2rem 0.65rem;
    border-radius: 99px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: 600;
  }

  .badge.work {
    background: #fef3c7;
    color: #92400e;
  }

  .badge.personal {
    background: #ede9fe;
    color: #5b21b6;
  }

  .card-arrow {
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    border: 1px solid var(--border);
    color: var(--fg);
    font-size: 1.1rem;
    text-decoration: none;
    transition: all 0.2s;
  }

  .card-arrow:hover {
    background: var(--fg);
    color: #fff;
    text-decoration: none;
  }

  h3 {
    font-family: 'Playfair Display', serif;
    font-size: 1.2rem;
  }

  .card-desc {
    color: var(--fg-secondary);
    font-size: 0.9rem;
    flex: 1;
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 0.25rem;
  }
</style>
