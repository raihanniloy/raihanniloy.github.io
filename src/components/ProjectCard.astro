---
import type { Project } from '../data/projects';

interface Props {
  project: Project;
}

const { project } = Astro.props;
---

<article class="card">
  <div class="card-header">
    <h3>{project.title}</h3>
    <span class:list={['badge', project.type]}>{project.type}</span>
  </div>
  <p class="card-desc">{project.description}</p>
  <div class="card-footer">
    <div class="tags">
      {project.tags.map(tag => <span class="tag">{tag}</span>)}
    </div>
    {project.url && (
      <a href={project.url} target="_blank" rel="noopener noreferrer" class="card-link">
        GitHub &rarr;
      </a>
    )}
  </div>
</article>

<style>
  .card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    transition: border-color 0.2s;
  }

  .card:hover {
    border-color: var(--accent);
  }

  .card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .card-header h3 {
    font-size: 1.1rem;
    color: var(--fg);
  }

  .badge {
    font-size: 0.7rem;
    padding: 0.15rem 0.5rem;
    border-radius: 99px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: 600;
    flex-shrink: 0;
  }

  .badge.work {
    background: rgba(56, 189, 248, 0.15);
    color: var(--accent);
    border: 1px solid rgba(56, 189, 248, 0.3);
  }

  .badge.personal {
    background: rgba(167, 139, 250, 0.15);
    color: #a78bfa;
    border: 1px solid rgba(167, 139, 250, 0.3);
  }

  .card-desc {
    color: var(--muted);
    font-size: 0.9rem;
    flex: 1;
  }

  .card-footer {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .card-link {
    font-size: 0.85rem;
    white-space: nowrap;
    flex-shrink: 0;
  }
</style>
